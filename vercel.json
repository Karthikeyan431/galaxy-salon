{
  "framework": null,
  "functions": {
    "api/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/content",
      "dest": "/api/content.js"
    },
    {
      "src": "/api/courses",
      "dest": "/api/courses.js"
    },
    {
      "src": "/api/login",
      "dest": "/api/login.js"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}