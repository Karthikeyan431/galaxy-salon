{
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/content",
      "dest": "/api/content.js"
    },
    {
      "src": "/api/courses",
      "dest": "/api/courses.js"
    },
    {
      "src": "/api/login",
      "dest": "/api/login.js"
    }
  ]
}